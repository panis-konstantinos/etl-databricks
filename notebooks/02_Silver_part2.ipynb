    "    COUNT(*) - COUNT(sales_order_number) AS null_order_num,\n",
    "    COUNT(*) - COUNT(order_date) AS null_date,\n",
    "    COUNT(*) - COUNT(product_key) AS null_prod_key,\n",
    "    COUNT(*) - COUNT(sales_amount) AS null_sales\n",
    "FROM project.silver.sales;"
