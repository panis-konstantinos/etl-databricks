    "-- Check for duplicate product keys in the Bronze layer \n",
    "-- (Identifies Primary Key violations before processing)\n",
    "SELECT \n",
    "    product_key, \n",
    "    COUNT(*) AS cnt\n",
    "FROM project.bronze.product\n",
    "GROUP BY product_key\n",
    "HAVING cnt > 1;"
